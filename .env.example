# Data Samanvayah Agent (DSA) - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# OpenAI API Configuration
# ============================================================================
OPENAI_API_KEY=sk_test_your_key_here
OPENAI_MODEL=gpt-4

# ============================================================================
# LangSmith Configuration (Optional - for observability)
# ============================================================================
LANGSMITH_API_KEY=your_langsmith_key_here
LANGSMITH_PROJECT=Data-Samanvayah-Agent

# ============================================================================
# Vector Store Configuration (Optional - for memory agent)
# ============================================================================
# Options: "qdrant", "chroma", "pinecone", "memory" (default)
VECTOR_STORE_TYPE=memory

# Qdrant Configuration (if VECTOR_STORE_TYPE=qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_key_here
QDRANT_COLLECTION_NAME=dsa_memory

# Chroma Configuration (if VECTOR_STORE_TYPE=chroma)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION_NAME=dsa_memory

# Pinecone Configuration (if VECTOR_STORE_TYPE=pinecone)
PINECONE_API_KEY=your_pinecone_key_here
PINECONE_INDEX_NAME=dsa-memory
PINECONE_ENVIRONMENT=us-west1-gcp

# ============================================================================
# Database Configuration
# ============================================================================
# Use SQLite for session persistence (optional)
USE_SQLITE_CHECKPOINTS=false
SQLITE_DB_PATH=./data/checkpoints/dsa.db

# ============================================================================
# Feature Flags
# ============================================================================
# Enable Human-in-the-Loop (HITL) for critic approval
ENABLE_HITL=true

# Enable LangSmith tracing for observability
ENABLE_LANGSMITH=false

# Enable verbose logging
LOG_LEVEL=INFO

# ============================================================================
# DSA Pipeline Configuration
# ============================================================================
# Maximum number of retries for failed operations
MAX_RETRIES=3

# Confidence threshold for automatic decisions (0.0-1.0)
CONFIDENCE_THRESHOLD=0.7

# Timeout for human approval requests (seconds)
HUMAN_APPROVAL_TIMEOUT=300
